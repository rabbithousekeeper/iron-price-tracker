# Supabase PostgreSQL接続URL
# Supabaseダッシュボード > Settings > Database > Connection string (URI) から取得
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# EIA API キー（https://www.eia.gov/opendata/register.php で無料取得）
EIA_API_KEY=your_eia_api_key_here

# 本番データ取得フラグ（falseの場合はスケジューラー無効化・モックデータ使用）
USE_REAL_DATA=true

# CORS許可オリジン（フロントエンドのURL）
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# データ取得間隔（時間）デフォルト: 168 = 週1回
FETCH_INTERVAL_HOURS=168
