# Garmin Connect認証情報
GARMIN_EMAIL=xxx@gmail.com
GARMIN_PASSWORD=xxxxx

# Supabase PostgreSQL接続URL
# Supabaseダッシュボード > Settings > Database > Connection string (URI) から取得
SUPABASE_DB_URL=postgresql://postgres.xxx:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# API認証キー（ランダムな文字列を設定）
API_KEY=your_random_api_key_here

# データ取得設定
FETCH_INTERVAL_HOURS=6
ACTIVITY_LIMIT=200
SYNC_DAYS_BACK=30

# タイムゾーン
TZ=Asia/Tokyo

# CORS許可オリジン
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
